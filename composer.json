{
    "name": "yayasanvitka/azure-oauth2-validator",
    "description": "Validates JWT from Azure OAuth2",
    "license": "MIT",
    "authors": [
        {
            "name": "Adli I. Ifkar",
            "email": "adly.shadowbane@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "PHP": "^8.3",
        "ext-json": "*",
        "ext-openssl": "*",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.20 || ^7.0 || ^8.0 || ^9.0 || ^10.0",
        "phpunit/phpunit": "^9.5 || ^10.5 || ^11.0",
        "laravel/pint": "^1.0",
        "pestphp/pest": "^1.20 || ^2.0",
        "pestphp/pest-plugin-parallel": "^0.3.1 || ^1.0 || ^2.0",
        "pestphp/pest-plugin-mock": "^1.0 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "Yayasanvitka\\AzureOauth2Validator\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Yayasanvitka\\AzureOauth2Validator\\Test\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yayasanvitka\\AzureOauth2Validator\\AzureOauth2ValidatorServiceProvider"
            ]
        }
    },
    "scripts": {
        "pint": "./vendor/bin/pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
